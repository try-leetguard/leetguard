# Local Docker development template.
# docker-compose.yml loads server/.env for API secrets.
# DATABASE_URL is shown for reference only; Compose overrides it so the API uses
# the Docker Postgres service at db:5432 instead of a host-machine database.

DATABASE_URL=postgresql+psycopg2://leetguard:leetguard@db:5432/leetguard
SECRET_KEY=local-dev-secret-key
REFRESH_SECRET_KEY=local-dev-refresh-secret-key
RESEND_API_KEY=local-dev-resend-api-key
FROM_EMAIL=noreply@leetguard.local
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
